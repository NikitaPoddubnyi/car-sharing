// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  firstName  String   @map("first_name") 
  lastName   String   @map("last_name")
  email     String      @unique
  password  String
  role      UserRole    @default(USER)
  referralCode String   @unique

  phone     String?        @unique 
  birthDate DateTime?      @map("birth_date")
  
  avatar    UserAvatar? @relation("user_avatar")
  license   DriverLicense?
  bookings  Booking[]    @relation("booking_user")

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("users")
}

model UserAvatar {
  id        String      @id @default(cuid())
  url       String
  
  user      User     @relation("user_avatar", fields: [userId], references: [id], onDelete: Cascade)
  userId    String      @unique @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_avatars")
}

model DriverLicense {
  id        String      @id @default(cuid())

  licenseNumber  String   @unique
  issueDate      DateTime 
  expiryDate     DateTime 
  country        String   @default("Ukraine")

  frontImage     String?  @map("front_image")
  backImage      String?  @map("back_image")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String      @unique 

  status        DriverLicenseStatus     @default(PENDING)

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("driver_licenses")
}

model Car {
  id        String      @id @default(cuid())
  brand         String   
  model         String   
  year          Int     
  
  bodyType      BodyType @default(SEDAN)
  seats         Int      // 2
  doors         Int      // 2
  luggage       Int      // Объем багажника (150)
  transmission  Transmission  @default(AUTOMATIC) 
  driveTrain    DriveTrain    @default(FWD)
  mileage       Int      // Пробег
  fuelType      FuelType      @default(PETROL)
  engineSize    Int      

  pricePerDay   Decimal  @db.Decimal(10, 2) 
  pricePerHour  Decimal  @db.Decimal(10, 2)

  location      Location @relation("cars_location", fields: [locationId], references: [id], onDelete: Restrict)
  locationId    String      @map("location_id")

  isAvailable   Boolean  @default(true)      
  
  description   String?  @db.Text           

  images        CarImage[]                  
  bookings      Booking[]  @relation("booking_car")                 

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("cars")
}

model Location {
  id        String      @id @default(cuid())
  name      String    @unique 
  city      String    
  lat       Float?    
  lng       Float?    

  cars      Car[]     @relation("cars_location")    
  bikes     Bike[]     @relation("bikes_location")    

  pickUpBookings  Booking[] @relation("PickUpLocation")
  dropOffBookings Booking[] @relation("DropOffLocation")

  @@map("locations")
}

model CarImage {
  id        String      @id @default(cuid())
  url       String
  car       Car    @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     String    @map("car_id")
  isPrimary Boolean @default(false)

  @@map("car_images")
}

model Bike {
  id        String      @id @default(cuid())
  brand         String   
  model         String   
  year          Int     
  
  groundClearance Int 
  engineDisplacement  Int
  emmisionType   String
  fuelType       FuelType      @default(PETROL)
  mileage       Int      // Пробег
  abs           String
  gearBox        GearBox @default(SPEED_5)
  tyreType       TyreType @default(FLAT)
  engineSize    Int      

  pricePerDay   Decimal  @db.Decimal(10, 2) 
  pricePerHour  Decimal  @db.Decimal(10, 2)

  location      Location @relation("bikes_location", fields: [locationId], references: [id], onDelete: Restrict)
  locationId    String      @map("location_id")

  isAvailable   Boolean  @default(true)      
  
  description   String?  @db.Text           

  images        BikeImage[]                  
  bookings      Booking[]  @relation("booking_bike")                  

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("bikes")
}

model BikeImage {
  id        String      @id @default(cuid())
  url       String
  bike       Bike    @relation(fields: [bikeId], references: [id], onDelete: Cascade)
  bikeId     String    @map("bike_id")
  isPrimary Boolean @default(false)

  @@map("bike_images")
}

model Booking {
  id        String      @id @default(cuid())
  bookingNo       String        @unique 
  
  // Связи
  user            User          @relation("booking_user",fields: [userId], references: [id])
  userId          String           @map("user_id")
  
  car             Car?           @relation("booking_car", fields: [carId], references: [id])
  carId           String?           @map("car_id")
  
  bike            Bike?          @relation("booking_bike", fields: [bikeId], references: [id])
  bikeId          String?           @map("bike_id")

  // География
  pickUpLocationId String @map("pick_up_location_id")
  pickUpLocation   Location @relation("PickUpLocation", fields: [pickUpLocationId], references: [id], onDelete: Restrict) 
  
  dropOffLocationId String? @map("drop_off_location_id")
  dropOffLocation  Location? @relation("DropOffLocation", fields: [dropOffLocationId], references: [id], onDelete: SetNull) 

  startDate       DateTime      @map("start_date") 
  endDate         DateTime      @map("end_date")   

  // Финансы
  totalPrice      Decimal       @db.Decimal(10, 2) @map("total_price") 

  status          BookingStatus @default(BOOKING)

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

enum GearBox {
  SPEED_5
  SPEED_6
  SPEED_7
}

enum TyreType {
  FLAT
  RIM
  TUBELESS
}

enum BookingStatus {
  BOOKING   
  COMPLETED 
  CANCELLED 
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
}

enum BodyType {
  SEDAN
  SUV
  COUPE
  HATCHBACK
  CONVERTIBLE
  CROSSOVER
  VAN
  PICKUP
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum DriveTrain {
  FWD
  RWD
  AWD
}

enum UserRole {
  USER
  ADMIN
}

enum DriverLicenseStatus {
  PENDING
  APPROVED
  REJECTED
}